# مرحله 1: بارگیری و آشنایی اولیه با داده
# ایمپورت کتابخانه‌ها
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# تنظیم برای نمایش بهتر نمودارها
plt.style.use('seaborn-v0_8-darkgrid')
sns.set_palette("husl")

# بارگیری دیتاست
df = pd.read_csv('data/space_missions.csv')

# ۱. مشاهده چند ردیف اول
print("🔍 پنج ردیف اول داده:")
display(df.head())

# ۲. بررسی اطلاعات کلی
print("\n📊 اطلاعات کلی داده:")
print(df.info())

# ۳. آمار توصیفی برای ستون‌های عددی
print("\n📈 آمار توصیفی:")
display(df.describe())

# ۴. بررسی مقادیر خالی
print("\n🧹 بررسی مقادیر خالی:")
print(df.isnull().sum())

# ۵. بررسی ستون‌های منحصر‌به‌فرد (برای ستون‌های متنی)
print("\n🏷️ تعداد شرکت‌های منحصر‌به‌فرد:", df['Company Name'].nunique())
print("🏷️ کشورهای منحصر‌به‌فرد:", df['Location'].nunique())
print("🏷️ وضعیت‌های منحصر‌به‌فرد:", df['Status'].unique())

# مرحله 2: تمیزکاری داده
# ۱. بررسی مجدد مقادیر خالی (اگر ستون Cost دارای مقادیر خالی باشد)
print("مقادیر خالی در ستون Cost:", df['Cost'].isnull().sum())

# ۲. (اختیاری) پر کردن یا حذف مقادیر خالی - اگر وجود داشتند
# df = df.dropna(subset=['Cost'])  # حذف ردیف‌های بدون هزینه

# ۳. تبدیل ستون تاریخ به فرمت تاریخ (اگر لازم باشد)
df['Date'] = pd.to_datetime(df['Date'])

# ۴. ایجاد ستون‌های جدید مفید
df['Year'] = df['Date'].dt.year
df['Month'] = df['Date'].dt.month

# ۵. نگاه نهایی به داده‌های تمیز شده
print("✅ داده‌ها پس از تمیزکاری:")
print(df.info())
display(df.head())

